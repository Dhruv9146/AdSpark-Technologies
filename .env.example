# =========================================================
# AdSpark Technologies - Environment Configuration Example
# Copy this file to .env in your local development environment
# or configure these keys in Netlify / Cloud Run dashboard.
# =========================================================

# 1. SUPABASE CLIENT INTEGRATION (Vite Public Keys)
# These are exposed to the browser to enable real-time database sync and secure Supabase Auth.
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key-here"

# 2. GEMINI AI INTENT INTEGRATION
# Server-side API key for processing AI operations and advanced technologies modules.
GEMINI_API_KEY="your-gemini-api-key-here"

# 3. APPLICATION RUNTIME ENVIRONMENT
# Auto-configured on cloud environments. Specifies self-referential endpoints.
APP_URL="http://localhost:3000"
NODE_ENV="development"
